<div class="editorial-split">
  {% for block in section.blocks %}
    <a href="{{ block.settings.link }}" class="editorial-panel" {{ block.shopify_attributes }}>
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | img_url: '1200x1600', crop: 'center' }}"
          alt="{{ block.settings.heading | escape }}"
          loading="lazy"
          width="1200"
          height="1600"
        >
      {% else %}
        <div style="width:100%;height:100%;background:{{ block.settings.fallback_color | default: '#2d4a2d' }}"></div>
      {% endif %}
      <div class="editorial-panel-content">
        {% if block.settings.label != blank %}
          <p class="label">{{ block.settings.label }}</p>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h3>{{ block.settings.heading }}</h3>
        {% endif %}
        {% if block.settings.cta_label != blank %}
          <span class="btn btn-white">{{ block.settings.cta_label }}</span>
        {% endif %}
      </div>
    </a>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Editorial Split",
  "max_blocks": 2,
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "color", "id": "fallback_color", "label": "Fallback color", "default": "#2d4a2d" },
        { "type": "text", "id": "label", "label": "Eyebrow label", "default": "New Drop" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "SHOP MEN" },
        { "type": "text", "id": "cta_label", "label": "Button label", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial Split",
      "blocks": [
        { "type": "panel" },
        { "type": "panel" }
      ]
    }
  ]
}
{% endschema %}
