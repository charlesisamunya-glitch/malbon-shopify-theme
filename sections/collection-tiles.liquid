<section class="collection-tiles-section">
  {% if section.settings.title != blank %}
    <div class="ct-header">
      <h2 class="ct-title">{{ section.settings.title }}</h2>
    </div>
  {% endif %}

  <div class="ct-grid ct-grid--{{ section.blocks.size }}">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link }}" class="ct-tile" {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | img_url: '900x1100', crop: 'center' }}"
            alt="{{ block.settings.label | escape }}"
            loading="lazy"
            width="900" height="1100"
          >
        {% else %}
          <div class="ct-tile-placeholder" style="background:{{ block.settings.fallback_color | default: '#1a1a1a' }}"></div>
        {% endif %}
        <div class="ct-tile-overlay">
          <p class="ct-tile-label">{{ block.settings.label }}</p>
          {% if block.settings.cta != blank %}
            <span class="ct-tile-btn">{{ block.settings.cta }}</span>
          {% endif %}
        </div>
      </a>
    {% endfor %}
  </div>
</section>

<style>
.collection-tiles-section {
  border-top: 1px solid rgba(0,0,0,0.08);
}

.ct-header {
  padding: 28px 24px 0;
}

.ct-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.ct-grid {
  display: grid;
  gap: 0;
}

.ct-grid--1 { grid-template-columns: 1fr; }
.ct-grid--2 { grid-template-columns: 1fr 1fr; }
.ct-grid--3 { grid-template-columns: repeat(3, 1fr); }
.ct-grid--4 { grid-template-columns: repeat(4, 1fr); }

@media (max-width: 768px) {
  .ct-grid--3,
  .ct-grid--4 { grid-template-columns: 1fr; }
  .ct-grid--2 { grid-template-columns: 1fr; }
}

.ct-tile {
  position: relative;
  display: block;
  aspect-ratio: 3/4;
  overflow: hidden;
}

.ct-tile img,
.ct-tile-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s ease;
}

.ct-tile:hover img { transform: scale(1.05); }

.ct-tile-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding-bottom: 40px;
  text-align: center;
}

.ct-tile-label {
  font-size: clamp(18px, 2.5vw, 28px);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: 16px;
  text-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

.ct-tile-btn {
  display: inline-block;
  padding: 10px 28px;
  border: 1px solid rgba(255,255,255,0.85);
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  transition: all 0.25s ease;
}

.ct-tile:hover .ct-tile-btn {
  background: #fff;
  color: #111;
}
</style>

{% schema %}
{
  "name": "Collection Tiles",
  "max_blocks": 4,
  "settings": [
    { "type": "text", "id": "title", "label": "Section title (optional)", "default": "Featured Collections" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collection Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "color", "id": "fallback_color", "label": "Fallback color", "default": "#2d4a2d" },
        { "type": "text", "id": "label", "label": "Category name", "default": "Icons" },
        { "type": "text", "id": "cta", "label": "Button label", "default": "Shop" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Tiles",
      "blocks": [
        { "type": "tile", "settings": { "label": "Icons", "cta": "Shop" } },
        { "type": "tile", "settings": { "label": "Performance", "cta": "Shop" } },
        { "type": "tile", "settings": { "label": "Headwear", "cta": "Shop" } }
      ]
    }
  ]
}
{% endschema %}
