<header class="site-header" role="banner">
  <div class="header-inner">

    <!-- Left: Main Nav -->
    <nav aria-label="Main navigation">
      <ul class="header-nav">
        {% for link in linklists.main-menu.links %}
          <li><a href="{{ link.url }}">{{ link.title }}</a></li>
        {% endfor %}
      </ul>
      <!-- Mobile hamburger -->
      <button class="hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </nav>

    <!-- Center: Logo -->
    <div class="site-logo">
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {% if section.settings.logo %}
          <img
            src="{{ section.settings.logo | img_url: '200x' }}"
            alt="{{ shop.name }}"
            width="120"
            height="auto"
            loading="eager"
          >
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- Right: Actions -->
    <div class="header-actions">
      <button data-open-search aria-label="Search">
        <svg class="icon-search" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="7"/><path d="m16.5 16.5 4 4"/>
        </svg>
      </button>

      {% if section.settings.show_currency %}
        <span>{{ localization.country.currency.iso_code }}</span>
      {% endif %}

      {% if section.settings.show_about %}
        <a href="{{ pages['about-us'].url | default: '/pages/about-us' }}">About Us</a>
      {% endif %}

      <a href="{{ routes.account_url }}">Account</a>

      <a href="{{ routes.cart_url }}" data-open-cart aria-label="Cart">
        Cart <span class="cart-count">({{ cart.item_count }})</span>
      </a>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image (leave blank to use shop name)"
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_about",
      "label": "Show About Us link",
      "default": true
    }
  ],
  "presets": [{ "name": "Header" }]
}
{% endschema %}
