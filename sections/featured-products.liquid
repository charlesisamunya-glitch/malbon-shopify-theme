<section class="featured-products-section" data-product-section>

  <div class="fp-header">
    <div class="fp-header-left">
      <h2 class="fp-title">{{ section.settings.title | default: 'Featured Releases' }}</h2>
      {% if section.settings.show_all_url != blank %}
        <a href="{{ section.settings.show_all_url }}" class="fp-shop-all">Shop All</a>
      {% endif %}
    </div>
  </div>

  <div class="fp-carousel-wrap">
    <button class="fp-arrow fp-prev" aria-label="Previous">&#8249;</button>
    <div class="fp-carousel">
      {% assign fp_collection = collections[section.settings.collection] %}
      {% if fp_collection == empty %}{% assign fp_collection = collections.all %}{% endif %}
      {% assign fp_limit = section.settings.product_limit | default: 8 %}
      {% for product in fp_collection.products limit: fp_limit %}
        <a href="{{ product.url }}" class="fp-card">
          <div class="fp-card-img">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}"
                alt="{{ product.featured_image.alt | escape | default: product.title }}"
                loading="lazy"
                width="600" height="800"
              >
            {% endif %}
            <button
              class="fp-quick-add"
              data-variant-id="{{ product.first_available_variant.id }}"
              aria-label="Quick add {{ product.title | escape }}"
              onclick="event.preventDefault();event.stopPropagation();"
            >+</button>
          </div>
          <div class="fp-meta">
            <span class="fp-badge">New Arrival</span>
          </div>
          <div class="fp-card-info">
            <p class="fp-product-name">{{ product.title }}</p>
            <p class="fp-product-price">{{ product.price | money }}</p>
            {% if product.options contains 'Color' %}
              <div class="fp-swatches">
                {% assign color_idx = 0 %}
                {% for opt in product.options_with_values %}
                  {% if opt.name == 'Color' %}{% assign color_idx = forloop.index0 %}{% endif %}
                {% endfor %}
                {% assign seen = '' %}
                {% for variant in product.variants %}
                  {% assign cv = variant.options[color_idx] | downcase | replace: ' ', '' %}
                  {% unless seen contains cv %}
                    {% assign seen = seen | append: cv | append: ',' %}
                    <span class="fp-swatch" style="background:{{ cv }};" title="{{ variant.options[color_idx] }}"></span>
                  {% endunless %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
    <button class="fp-arrow fp-next" aria-label="Next">&#8250;</button>
  </div>

</section>

<style>
.featured-products-section {
  padding: 0 0 48px;
  border-top: 1px solid rgba(0,0,0,0.08);
}

.fp-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28px 24px 20px;
}

.fp-header-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.fp-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.fp-shop-all {
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: 1px solid #111;
  padding: 5px 12px;
  color: #111;
  transition: all 0.25s ease;
}

.fp-shop-all:hover {
  background: #111;
  color: #fff;
}

.fp-carousel-wrap {
  position: relative;
}

.fp-carousel {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: calc(25% - 1px);
  gap: 1px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  background: rgba(0,0,0,0.06);
}

.fp-carousel::-webkit-scrollbar { display: none; }

@media (max-width: 1024px) { .fp-carousel { grid-auto-columns: calc(33.333% - 1px); } }
@media (max-width: 640px)  { .fp-carousel { grid-auto-columns: calc(50% - 1px); } }

.fp-card {
  background: #fff;
  scroll-snap-align: start;
  position: relative;
  display: block;
  color: inherit;
  text-decoration: none;
}

.fp-card-img {
  position: relative;
  aspect-ratio: 3/4;
  background: #f0ece4;
  overflow: hidden;
}

.fp-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.fp-card:hover .fp-card-img img { transform: scale(1.04); }

.fp-quick-add {
  position: absolute;
  bottom: 12px;
  right: 12px;
  width: 36px;
  height: 36px;
  background: #fff;
  border: 1px solid rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  cursor: pointer;
  opacity: 0;
  transition: all 0.25s ease;
}

.fp-card:hover .fp-quick-add { opacity: 1; }
.fp-quick-add:hover { background: #111; color: #fff; border-color: #111; }

.fp-meta {
  padding: 8px 14px 0;
}

.fp-badge {
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #888;
}

.fp-card-info {
  padding: 4px 14px 18px;
}

.fp-product-name {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 4px;
  line-height: 1.3;
}

.fp-product-price {
  font-size: 11px;
  color: #888;
  margin-bottom: 8px;
}

.fp-swatches {
  display: flex;
  gap: 5px;
  flex-wrap: wrap;
}

.fp-swatch {
  width: 13px;
  height: 13px;
  border-radius: 50%;
  border: 1px solid rgba(0,0,0,0.15);
  display: inline-block;
  cursor: pointer;
}

/* Carousel arrows */
.fp-arrow {
  position: absolute;
  top: 42%;
  transform: translateY(-50%);
  background: #fff;
  border: 1px solid rgba(0,0,0,0.12);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  cursor: pointer;
  z-index: 10;
  transition: all 0.2s ease;
  color: #111;
  line-height: 1;
}

.fp-arrow:hover { background: #111; color: #fff; }
.fp-prev { left: 12px; }
.fp-next { right: 12px; }
</style>

<script>
(function() {
  document.querySelectorAll('.featured-products-section').forEach(section => {
    const carousel = section.querySelector('.fp-carousel');
    const prev = section.querySelector('.fp-prev');
    const next = section.querySelector('.fp-next');

    if (prev && next && carousel) {
      const scrollBy = () => carousel.querySelector('.fp-card')?.offsetWidth || 300;
      prev.addEventListener('click', () => carousel.scrollBy({ left: -scrollBy(), behavior: 'smooth' }));
      next.addEventListener('click', () => carousel.scrollBy({ left: scrollBy(), behavior: 'smooth' }));
    }
  });
})();
</script>

{% schema %}
{
  "name": "Product Carousel",
  "settings": [
    { "type": "text", "id": "title", "label": "Section title", "default": "Featured Releases" },
    { "type": "url", "id": "show_all_url", "label": "\"Shop All\" link" },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "product_limit", "label": "Products to show", "min": 4, "max": 24, "step": 1, "default": 8 }
  ],
  "presets": [{ "name": "Product Carousel" }]
}
{% endschema %}
