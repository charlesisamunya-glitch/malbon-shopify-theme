<div class="container" style="max-width:900px;margin:0 auto;padding:60px 24px;">
  <h1 style="font-size:14px;font-weight:700;letter-spacing:.15em;text-transform:uppercase;margin-bottom:40px;">Your Cart</h1>

  {% if cart.item_count == 0 %}
    <p style="color:#888;margin-bottom:24px;">Your cart is empty.</p>
    <a href="{{ routes.all_products_collection_url }}" class="btn btn-black">Continue Shopping</a>
  {% else %}
    {% form 'cart', cart %}
      {% for item in cart.items %}
        <div style="display:grid;grid-template-columns:100px 1fr auto;gap:24px;padding:24px 0;border-bottom:1px solid rgba(0,0,0,0.08);">
          <a href="{{ item.url }}">
            <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title | escape }}" style="width:100%;object-fit:cover;">
          </a>
          <div>
            <p style="font-size:12px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:4px;">{{ item.product.title }}</p>
            {% unless item.variant.title == 'Default Title' %}
              <p style="font-size:11px;color:#888;margin-bottom:8px;">{{ item.variant.title }}</p>
            {% endunless %}
            <p style="font-size:12px;color:#888;">{{ item.final_price | money }}</p>
          </div>
          <div style="text-align:right;">
            <input type="number" name="updates[]" value="{{ item.quantity }}" min="0"
              style="width:48px;border:1px solid #ddd;padding:4px 8px;text-align:center;font-size:13px;">
            <p style="font-size:12px;font-weight:600;margin-top:8px;">{{ item.final_line_price | money }}</p>
          </div>
        </div>
      {% endfor %}

      <div style="margin-top:32px;text-align:right;">
        <p style="font-size:14px;font-weight:600;margin-bottom:20px;">
          Subtotal: <span>{{ cart.total_price | money }}</span>
        </p>
        <button type="submit" name="checkout" class="btn btn-black" style="padding:16px 48px;">
          Checkout
        </button>
      </div>
    {% endform %}
  {% endif %}
</div>

{% schema %}
{ "name": "Cart", "settings": [], "presets": [{ "name": "Cart" }] }
{% endschema %}
